{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=cfs_db;Username=postgres;Password=admin;"
  },
  "JwtSettings": {
    "Key": "ThisIsAStrongSecretKeyThatShouldBeAtLeast256BitsLongAndStoredSecurely",
    "Issuer": "https://localhost:7000",
    "Audience": "https://localhost:3000",
    "ExpireDays": 7
  },
  "CorsOrigins": "http://localhost:5173",
  "Serilog": {
    "Using": [ "Serilog.Sinks.PostgreSQL" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "PostgreSQL",
        "Args": {
          "connectionString": "Host=localhost;Port=5432;Database=cfs_db;Username=postgres;Password=admin;",
          "tableName": "audit_logs",
          "needAutoCreateSqlTable": true,
          "schemaName": "public",
          "columnOptions": {
            "LogEvent": {
              "DataType": "jsonb",
              "ExcludeFromStandardColumns": true
            },
            "Id": {
              "ExcludeFromStandardColumns": true
            },
            "Message": {
              "ColumnName": "logstr",
              "DataType": "varchar(255)",
              "ExcludeFromStandardColumns": false
            },
            "MessageTemplate": {
              "ExcludeFromStandardColumns": true
            },
            "Level": {
              "ExcludeFromStandardColumns": true
            },
            "Timestamp": {
              "ColumnName": "log_time",
              "DataType": "timestamp",
              "ExcludeFromStandardColumns": false
            },
            "Exception": {
              "ExcludeFromStandardColumns": true
            },
            "Properties": {
              "ExcludeFromStandardColumns": true
            }
          }
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId", "WithThreadId" ],
    "Properties": {
      "Application": "CashFlowSystem"
    }
  },
  "AppSettings": {
    "HomeCurrency": "SGD",
    "DuplicateCheckDays": 14,
    "Date1Add": -1,
    "Date2Add": 0,
    "ReportPath": "Reports/",
    "LogClosingSql": "insert into audit_logs (logid, user_id, logstr, log_time) values ('{LogId}', '{UserId}', 'CLOSE {Dept}', '{LogTime}')"
  },
  "Reports": {
    "Day End Summary": {
      "FileName": "CFS-100.rpx",
      "Permissions": "0110000",
      "Description": "Daily summary of all transactions."
    },
    "Ad-Hoc Summary": {
      "FileName": "CFS-110.rpx",
      "Permissions": "0110000",
      "Description": "Custom summary report for specific criteria."
    }
  },
  "StatusTypes": {
    "E": { "Description": "Correction", "ColorHex": "00FFFF" },
    "K": { "Description": "Cancel", "ColorHex": "000000" },
    "U": { "Description": "Upload", "ColorHex": "0000FF" },
    "M": { "Description": "Unchecked", "ColorHex": "00000F" }
  },
  "SqlQueries": {
    "GetNostroAccounts": "SELECT data01 FROM misc_settings WHERE dataid1 = 'NOSTRO' AND dataid2 = '{Currency}'",
    "CheckDuplicate": "SELECT dr_cur AS \"Currency\", dr_amount AS \"Amount\", reference AS \"Reference\", value_date AS \"ValueDate\", CONCAT(dr_acct, '-', cr_acct) AS \"AccountPair\" FROM position_reports WHERE dept = '{Dept}' AND dr_acct = '{DrAcct}' AND dr_cur = '{DrCur}' AND dr_amount = {DrAmount} AND cr_acct = '{CrAcct}' AND cr_cur = '{CrCur}' AND cr_amount = {CrAmount} AND value_date > '{ValueDateMinusDays}' AND uid <> '{Uid}'"
  }
}